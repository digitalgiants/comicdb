POSTGRES_DB=comicvault
POSTGRES_USER=comicvault
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://comicvault:change-me@db:5432/comicvault?schema=public

JWT_SECRET=replace-with-a-long-random-secret
FRONTEND_ORIGIN=http://localhost:8090
PUBLIC_API_BASE_URL=http://localhost:8084

# Optional Google login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8084/auth/google/callback

# Optional comic metadata and pricing integrations
# Comic Vine: free key after account signup at https://comicvine.gamespot.com/api/
COMICVINE_API_KEY=
# eBay Browse API: requires an eBay developer app client id/secret
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
