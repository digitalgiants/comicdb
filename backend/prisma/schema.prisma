generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  role         Role     @default(USER)
  passwordHash String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  comics       Comic[]
}

model Comic {
  id           String   @id @default(cuid())
  userId       String
  title        String
  writer       String?
  artist       String?
  penciler     String?
  inker        String?
  pricePaid    Decimal  @default(0) @db.Decimal(10, 2)
  currentPrice Decimal  @default(0) @db.Decimal(10, 2)
  coverUrl     String?
  source       String?
  sourceId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, title])
}
